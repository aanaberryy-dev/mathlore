<!DOCTYPE html>
<html lang="ru" data-theme="<%= user.theme %>">
<head>
  <meta charset="UTF-8"><title>Финансы | Журнал репетитора</title>
  <link rel="stylesheet" href="/style.css">
  <style>.cards{display:grid;grid-template-columns:repeat(3,1fr);gap:15px;margin-bottom:25px}.card{text-align:center}.card .num{font-size:28px;font-weight:700}.green{color:var(--green)}.red{color:var(--red)}.blue{color:var(--blue)}.add-form{display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;margin-bottom:20px}.income{color:var(--green);font-weight:bold}.expense{color:var(--red);font-weight:bold}.del{color:var(--red);text-decoration:none;font-weight:bold}@media(max-width:600px){.cards{grid-template-columns:1fr}}</style>
</head>
<body>
  <div class="header"><div class="logo">📚 <span>ЖУРНАЛ</span> РЕПЕТИТОРА</div><div class="header-right"><span class="badge">👑 Премиум</span><div class="avatar"><%= user.name.charAt(0).toUpperCase() %></div><span><%= user.name %></span><a href="/theme/<%= user.theme==='dark'?'light':'dark' %>">🌙</a><a href="/logout" class="logout">🚪</a></div></div>
  <div class="menu"><a href="/dashboard">🏠 Главная</a><a href="/calendar">📅 Расписание</a><a href="/students">👨‍🎓 Ученики</a><a href="/groups">👥 Группы</a><a href="/finances" class="active">💰 Финансы</a><a href="/library">📚 Библиотека</a><a href="/analytics">📊 Аналитика</a><a href="/settings">⚙️ Настройки</a></div>
  <div class="content">
    <div class="cards"><div class="card"><div class="num green"><%= totalIncome %> <%= user.currency||'BYN' %></div><div style="color:var(--text2);">Доходы</div></div><div class="card"><div class="num red"><%= totalExpense %> <%= user.currency||'BYN' %></div><div style="color:var(--text2);">Расходы</div></div><div class="card"><div class="num blue"><%= totalIncome-totalExpense %> <%= user.currency||'BYN' %></div><div style="color:var(--text2);">Баланс</div></div></div>
    <div class="card add-form"><form action="/finances/add" method="POST" style="display:flex;gap:10px;flex-wrap:wrap;"><input type="number" step="0.01" name="amount" placeholder="Сумма" required><select name="type"><option value="income">Доход</option><option value="expense">Расход</option></select><input type="text" name="category" placeholder="Категория"><input type="text" name="description" placeholder="Описание"><input type="date" name="date" required><button class="btn btn-green">Добавить</button></form></div>
    <h3>📋 История</h3><table><tr><th>Дата</th><th>Тип</th><th>Категория</th><th>Описание</th><th>Сумма</th><th></th></tr><% finances.forEach(function(f){%><tr><td><%= f.date %></td><td><%= f.type==='income'?'📥 Доход':'📤 Расход' %></td><td><%= f.category||'—' %></td><td><%= f.description||'—' %></td><td class="<%= f.type %>"><%= f.type==='income'?'+':'-' %><%= f.amount %> <%= user.currency||'BYN' %></td><td><a href="/finances/delete/<%= f.id %>" onclick="return confirm('Удалить?')" class="del">✕</a></td></tr><%})%></table>
  </div>
</body>
</html>